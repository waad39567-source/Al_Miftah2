      "name": "السيناريو 1: التسجيل العادي (توثيق من الأدمن)",
      "item": [
        {
          "name": "1.1 تسجيل مستخدم جديد",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تم التسجيل بنجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('الحالة 201', function() {",
                  "    pm.expect(pm.response.status).to.eq(201);",
                  "});",
                  "pm.environment.set('newUserEmail', pm.response.json().data.user.email);",
                  "pm.environment.set('newUserId', pm.response.json().data.user.id);",
                  "pm.test('الحساب غير موثق', function() {",
                  "    pm.expect(pm.response.json().data.user.email_verified_at).to.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"مستخدم جديد\",\n  \"email\": \"newuser_{{$randomInt}}@test.com\",\n  \"phone\": \"96655{{$randomInt}}\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
