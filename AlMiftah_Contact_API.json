                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.environment.set('ownerToken', pm.response.json().data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner1@almiftah.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "1.3 تسجيل دخول الأدمن",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تم تسجيل دخول الأدمن', function() {",
