{
  "info": {
    "name": "شركة المفتاح - اختبار طلبات التواصل",
    "description": "مجموعة اختبار شاملة لطلبات التواصل\n\n# سير العمل:\n1. مستخدم يرسل طلب تواصل لعقار\n2. الأدمن يوافق أو يرفض الطلب\n3. مالك العقار يرى الطلبات المستلمة\n4. المستخدم يرى حالة طلباته\n\n# الطريقة:\n1. أنشئ متغير baseUrl: http://127.0.0.1:8000/api\n2. ضع التوكنات المناسبة\n3. شغل السيناريوهات بالترتيب",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "ownerToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "contactRequestId", "value": "" },
    { "key": "ownerId", "value": "" }
  ],
  "item": [
    {
      "name": "1. إعداد - تسجيل الدخول",
      "item": [
        {
          "name": "1.1 تسجيل دخول الأدمن",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم تسجيل الدخول', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "if (pm.response.json().data && pm.response.json().data.token) {",
                  "    pm.environment.set('adminToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@almiftah.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "1.2 تسجيل دخول مالك العقار (Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم تسجيل الدخول', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "if (pm.response.json().data && pm.response.json().data.token) {",
                  "    pm.environment.set('ownerToken', pm.response.json().data.token);",
                  "    pm.environment.set('ownerId', pm.response.json().data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "1.3 تسجيل دخول المستخدم",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم تسجيل الدخول', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "if (pm.response.json().data && pm.response.json().data.token) {",
                  "    pm.environment.set('userToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. إعداد - إنشاء عقار للاختبار",
      "item": [
        {
          "name": "2.1 مالك العقار ينشئ عقار",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم إنشاء العقار', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.environment.set('propertyId', pm.response.json().data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/properties",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ownerToken}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"شقة للاختبار\",\n  \"description\": \"شقة فاخرة 3 غرف نوم\",\n  \"price\": 150000,\n  \"type\": \"sale\",\n  \"property_type\": \"apartment\",\n  \"area\": 120,\n  \"region_id\": 1,\n  \"location\": \"دمشق - المزة\"\n}"
            }
          }
        },
        {
          "name": "2.2 الأدمن يوافق على العقار",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم الموافقة', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/properties/{{propertyId}}/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
