    {
      "name": "4. عرض طلبات المستخدم",
      "item": [
        {
          "name": "4.1 المستخدم يرى طلباته المرسلة",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('نجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('يوجد طلبات', function() {",
                  "    pm.expect(pm.response.json().data.total).to.greaterThan(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/contact/my-requests",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "4.2 فلترة طلبات المستخدم حسب الحالة - معلق",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('نجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/contact/my-requests?status=pending",
              "host": ["{{baseUrl}}"],
              "path": ["contact", "my-requests"],
              "query": [
                { "key": "status", "value": "pending" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        },
        {
          "name": "4.3 فحص حالة طلب معين",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('نجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('لديه طلب', function() {",
                  "    pm.expect(pm.response.json().data.has_request).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/contact/status/{{propertyId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
