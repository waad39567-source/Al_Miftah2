                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/regions/root/list",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "2.4 عرض أنواع المناطق",
          "description": "ترجع قائمة بأنواع المناطق المتاحة",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ نجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('يحتوي على الأنواع', function() {",
                  "    var data = pm.response.json().data;",
                  "    pm.expect(data.country).to.not.be.undefined;",
                  "    pm.expect(data.governorate).to.not.be.undefined;",
                  "    pm.expect(data.city).to.not.be.undefined;",
                  "    pm.expect(data.neighborhood).to.not.be.undefined;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/regions/types/list",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        }
      ]
    },
