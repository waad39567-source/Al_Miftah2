{
  "info": {
    "name": "شركة المفتاح - المصادقة",
    "description": "# شركة المفتاح - Authentication API\n\n## نظرة عامة\nواجهة برمجة التطبيقات للمصادقة تتضمن 3 سيناريوهات:\n\n### السيناريو 1: التسجيل العادي (بدون توثيق)\n- المستخدم يسجل\n- الأدمن يوثقه يدوياً\n- المستخدم يسجل دخول\n\n### السيناريو 2: التوثيق عبر الإيميل\n- المستخدم يسجل\n- يرسل رابط التوثيق\n- يوثق عبر API\n- يسجل دخول\n\n### السيناريو 3: تغيير كلمة المرور\n- المستخدم يسجل دخول\n- يغير كلمة المرور\n\n---\n\n## الـ Base URL\n```\n{{baseUrl}}\n```\n\n---\n\n## credentials:\n- Admin: admin@almiftah.com / admin123\n- Owner: owner1@almiftah.com / password123\n- User: user1@test.com / password123\n\n## الأدوار (role)\n| القيمة | الوصف |\n|--------|-------|\n| user | مستخدم عادي |\n| owner | مالك عقارات |\n| admin | مدير النظام |\n\n## حالة الحساب\n| الحقل | الوصف |\n|-------|-------|\n| is_active | هل الحساب نشط |\n| is_banned | هل الحساب محظور |\n| email_verified_at | تاريخ توثيق الإيميل (null = غير موثق) |\n\n## رموز حالة تسجيل الدخول\n| القيمة | المعنى |\n|--------|-------|\n| null | نجاح |\n| false | الحساب غير نشط |\n| \"banned\" | الحساب محظور |\n| \"unverified\" | الحساب غير موثق |\n| \"\" (فارغ) | بيانات خاطئة |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://al-miftah-master-enqeji.free.laravel.cloud/api" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "ownerToken", "value": "" },
    { "key": "newUserEmail", "value": "" },
    { "key": "newUserId", "value": "" },
    { "key": "newUserEmail2", "value": "" }
  ],
  "item": [
    {
      "name": "السيناريو 1: التسجيل العادي (توثيق من الأدمن)",
      "item": [
        {
          "name": "1.1 تسجيل مستخدم جديد",
          "description": "تسجيل مستخدم جديد. الدور الافتراضي هو user.",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تم التسجيل بنجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('الحالة 201', function() {",
                  "    pm.expect(pm.response.status).to.eq(201);",
                  "});",
                  "pm.environment.set('newUserEmail', pm.response.json().data.user.email);",
                  "pm.environment.set('newUserId', pm.response.json().data.user.id);",
                  "pm.test('الحساب غير موثق', function() {",
                  "    pm.expect(pm.response.json().data.user.email_verified_at).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"مستخدم جديد\",\n  \"email\": \"newuser_{{$randomInt}}@test.com\",\n  \"phone\": \"96655{{$randomInt}}\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "1.2 تسجيل دخول - ❌ تفشل (غير موثق)",
          "description": "محاولة تسجيل دخول قبل توثيق الحساب",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ فشل - الحساب غير موثق', function() {",
                  "    pm.expect(pm.response.json().success).to.be.false;",
                  "});",
                  "pm.test('رسالة الخطأ', function() {",
                  "    pm.expect(pm.response.json().message).to.contain('موثق');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "1.3 تسجيل دخول الأدمن",
          "description": "الأدمن يسجل دخول لإدارة المستخدمين",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تم تسجيل دخول الأدمن', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.environment.set('adminToken', pm.response.json().data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@almiftah.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "1.4 الأدمن يوثق المستخدم",
          "description": "الأدمن يوثق المستخدم الجديد يدوياً",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تم توثيق المستخدم', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('الحساب موثق الآن', function() {",
                  "    pm.expect(pm.response.json().data.email_verified_at).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/users/{{newUserId}}/verify",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "1.5 تسجيل دخول المستخدم - ✅ نجاح",
          "description": "تسجيل دخول بعد توثيق الحساب",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('✓ تسجيل دخول ناجح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.test('يحتوي على token', function() {",
                  "    pm.expect(pm.response.json().data.token).to.not.be.undefined;",
                  "});",
                  "pm.environment.set('userToken', pm.response.json().data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
