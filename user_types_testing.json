{
  "info": {
    "name": "Al-Miftah API - User Types Testing",
    "description": "Testing 3 user types: admin, user, owner",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "owner_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "===== ADMIN SCENARIO =====",
      "item": [
        {
          "name": "1. Admin Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@almiftah.com\",\n    \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "2. Admin - Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "3. Admin - Create User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مستخدم جديد من الادمن\",\n    \"email\": \"newuser@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"user\",\n    \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "4. Admin - Create Owner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مالك عقار من الادمن\",\n    \"email\": \"newowner@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"owner\",\n    \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "5. Admin - Create Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/users",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مدير جديد من الادمن\",\n    \"email\": \"newadmin@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"admin\",\n    \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "6. Admin - Promote to Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/promote-to-admin",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "7. Admin - Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/change-password",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"current_password\": \"admin123\",\n    \"password\": \"admin123\",\n    \"password_confirmation\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "8. Admin - Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        }
      ]
    },
