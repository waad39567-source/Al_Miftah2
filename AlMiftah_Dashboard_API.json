{
  "info": {
    "name": "AlMiftah - Dashboard API",
    "description": "Dashboard APIs for Admin Panel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "https://al-miftah-master-enqeji.free.laravel.cloud/api"},
    {"key": "adminToken", "value": ""}
  ],
  "item": [
    {
      "name": "0. Login",
      "item": [
        {
          "name": "0.1 Admin Login",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Login success', function() {", "    pm.expect(pm.response.json().success).to.be.true;", "});", "pm.environment.set('adminToken', pm.response.json().data.token);"]}}],
          "request": {"method": "POST", "url": "{{baseUrl}}/auth/login", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"email\": \"admin@almiftah.com\", \"password\": \"admin123\"}"}}
        }
      ]
    },
    {
      "name": "1. Statistics",
      "item": [{"name": "1.1 Overview Statistics", "request": {"method": "GET", "url": "{{baseUrl}}/admin/statistics", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}]
    },
    {
      "name": "2. Chart Data",
      "item": [{"name": "2.1 Chart Data", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/chart-data", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}]
    },
    {
      "name": "3. Properties Distribution",
      "item": [
        {"name": "3.1 By Region", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/properties-by-region", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "3.2 By Type", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/properties-by-type", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}
      ]
    },
    {
      "name": "4. Properties Summary",
      "item": [
        {"name": "4.1 All", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/properties-summary", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "4.2 Sold", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/properties-summary?type=sold", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "4.3 Rented", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/properties-summary?type=rented", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}
      ]
    },
    {
      "name": "5. Users Registration",
      "item": [
        {"name": "5.1 Daily", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/users-registration?period=daily", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "5.2 Weekly", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/users-registration?period=weekly", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "5.3 All", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/users-registration?period=all", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}
      ]
    },
    {
      "name": "6. Top Active Regions",
      "item": [
        {"name": "6.1 Top 10", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/top-active-regions", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "6.2 Top 5", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/top-active-regions?limit=5", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}
      ]
    },
    {
      "name": "7. Recent Activities",
      "item": [
        {"name": "7.1 Default 10", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/recent-activities", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}},
        {"name": "7.2 Last 5", "request": {"method": "GET", "url": "{{baseUrl}}/admin/dashboard/recent-activities?limit=5", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"]}}}
      ]
    }
  ]
}
