{
  "info": {
    "name": "AlMiftah - Dashboard APIs",
    "description": "Dashboard APIs for Admin Panel - لوحه تحكم الأدمن\n\nBase URL: {{baseUrl}}\n\nملاحظة: يجب إضافة Authorization Header يدوياً: Bearer YOUR_ADMIN_TOKEN",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://al-miftah-master-enqeji.free.laravel.cloud/api"
    },
    {
      "key": "adminToken",
      "value": "YOUR_ADMIN_TOKEN_HERE"
    }
  ],
  "item": [
    {
      "name": "1. الإحصائيات",
      "item": [
        {
          "name": "1.1 الإحصائيات الشاملة",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/statistics",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "2. بيانات الرسم البياني",
      "item": [
        {
          "name": "2.1 Chart Data",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/chart-data",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "3. توزيع العقارات",
      "item": [
        {
          "name": "3.1 حسب المنطقة",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/properties-by-region",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "3.2 حسب النوع",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/properties-by-type",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "4. ملخص العقارات",
      "item": [
        {
          "name": "4.1 الكل",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/properties-summary",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "4.2 المباعة",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/properties-summary?type=sold",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "4.3 المؤجرة",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/properties-summary?type=rented",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "5. تسجيل المستخدمين",
      "item": [
        {
          "name": "5.1 يومياً",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/users-registration?period=daily",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "5.2 أسبوعياً",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/users-registration?period=weekly",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "5.3 إجمالي",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/users-registration?period=all",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "6. المناطق النشطة",
      "item": [
        {
          "name": "6.1 أكثر 10 مناطق",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/top-active-regions",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "6.2 أكثر 5 مناطق",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/top-active-regions?limit=5",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    },
    {
      "name": "7. آخر الأنشطة",
      "item": [
        {
          "name": "7.1 الكل (افتراضي 10)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/recent-activities",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "7.2 آخر 5",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard/recent-activities?limit=5",
            "header": [
              {"key": "Authorization", "value": "Bearer {{adminToken}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        }
      ]
    }
  ]
}
