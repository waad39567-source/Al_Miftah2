{
  "info": {
    "name": "شركة المفتاح - اختبار المصادقة",
    "description": "مجموعة اختبار شاملة للمصادقة لأنواع المستخدمين الثلاثة\n\n# أنواع المستخدمين:\n- Admin: مدير النظام (دور: admin)\n- Office: مكتب عقاري (دور: owner)\n- User: مستخدم عادي (دور: user)\n\n# الطريقة:\n1. أنشئ متغير baseUrl: http://127.0.0.1:8000/api\n2. شغل السيناريوهات بالترتيب\n3. ستتمكن من اختبار تسجيل الخروج وتسجيل الدخول لجميع الأنواع",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "adminEmail", "value": "admin@almiftah.com" },
    { "key": "ownerToken", "value": "" },
    { "key": "ownerEmail", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "userEmail", "value": "" },
    { "key": "random", "value": "{{$randomInt}}" }
  ],
  "item": [
    {
      "name": "1. تسجيل مستخدمين جدد (User, Owner, Admin)",
      "item": [
        {
          "name": "1.1 تسجيل مستخدم عادي (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم التسجيل بنجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.environment.set('userEmail', pm.response.json().data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"مستخدم عادي\",\n  \"email\": \"user_{{$randomInt}}@test.com\",\n  \"phone\": \"966501{{$randomInt}}001\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "1.2 تسجيل مكتب عقاري (Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم التسجيل بنجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "pm.environment.set('ownerEmail', pm.response.json().data.user.email);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"مكتب المفتاح للعقارات\",\n  \"email\": \"owner_{{$randomInt}}@test.com\",\n  \"phone\": \"966501{{$randomInt}}002\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"owner\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. تسجيل دخول - Login",
      "item": [
        {
          "name": "2.1 تسجيل دخول - مستخدم عادي (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تسجيل دخول ناجح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "if (pm.response.json().data && pm.response.json().data.token) {",
                  "    pm.environment.set('userToken', pm.response.json().data.token);",
                  "    pm.environment.set('userEmail', pm.response.json().data.user.email);",
                  "}",
                  "pm.test('الدور مستخدم عادي', function() {",
                  "    pm.expect(pm.response.json().data.user.role).to.eq('user');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
