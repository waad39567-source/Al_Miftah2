{
  "info": {
    "name": "Al-Miftah API",
    "description": "Testing all authentication features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Register - User",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/register",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"مستخدم عادي\",\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"01234567890\",\n    \"role\": \"user\"\n}"
        }
      }
    },
    {
      "name": "2. Register - Owner",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/register",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"مالك عقار\",\n    \"email\": \"owner@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"01234567891\",\n    \"role\": \"owner\"\n}"
        }
      }
    },
    {
      "name": "3. Register - Invalid Role",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/register",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"تجربة\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"admin\"\n}"
        }
      }
    },
    {
      "name": "4. Login - Success",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "5. Login - Wrong Password",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"wrongpassword\"\n}"
        }
      }
    },
    {
      "name": "6. Login - Invalid Email",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"notfound@example.com\",\n    \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "7. Get Current User (Me)",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/auth/me",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "8. Change Password",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/change-password",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"current_password\": \"password123\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
        }
      }
    },
    {
      "name": "9. Change Password - Wrong Current",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/change-password",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"current_password\": \"wrongpassword\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
        }
      }
    },
    {
      "name": "10. Logout",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/logout",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    },
    {
      "name": "11. Login After Password Change",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/login",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"newpassword123\"\n}"
        }
      }
    },
    {
      "name": "12. Promote to Admin (By ID)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/promote-to-admin",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"id\": 2\n}"
        }
      }
    },
    {
      "name": "13. Promote to Admin (By Email)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/promote-to-admin",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"owner@example.com\"\n}"
        }
      }
    },
    {
      "name": "14. Promote - User Not Found",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/auth/promote-to-admin",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"id\": 999\n}"
        }
      }
    },
    {
      "name": "15. Protect Route Without Token",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/auth/me",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ]
      }
    }
  ]
}
