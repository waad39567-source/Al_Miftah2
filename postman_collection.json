          }
        },
        {
          "name": "6. إنشاء منطقة - مستخدم عادي (فشل) ✗",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('غير مصرح - 403', function() {",
                  "    pm.expect(pm.response.status).to.equal(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/regions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"حي تجريبي\",\n  \"type\": \"neighborhood\"\n}"
            }
          }
        },
        {
          "name": "7. حذف منطقة - أدمن فقط ✓",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/regions/{{regionId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        }
      ]
    },
