        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"مستخدم غير موثق\",\n    \"email\": \"{{unverified_user_email}}\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"966503333333\",\n    \"role\": \"user\"\n}"
        }
      },
      "response": []
