{
  "info": {
    "name": "شركة المفتاح - API Testing",
    "description": "مجموعة اختبار شاملة لجميع سيناريوهات النظام\n\n# الأدوار:\n- Admin: له كل الصلاحيات\n- User: مستخدم عادي\n- Office: مكتب عقاري\n\n# الطريقة:\n1. أنشئ متغير baseUrl: http://127.0.0.1:8000/api\n2. شغل سيناريو تسجيل الدخول للحصول على التوكن\n3. ضع التوكن في المتغيرات المناسبة\n4. شغل باقي السيناريوهات",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000/api" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "officeToken", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "regionId", "value": "" },
    { "key": "contactRequestId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - المصادقة / Auth",
      "item": [
        {
          "name": "1. تسجيل مستخدم جديد",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم التسجيل بنجاح', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "});",
                  "if (pm.response.json().data.token) {",
                  "    pm.environment.set('userToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"مستخدم تجريبي\",\n  \"email\": \"testuser{{$randomInt}}@test.com\",\n  \"phone\": \"966501{{$randomInt}}\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "2. تسجيل دخول - نجاح",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('تم تسجيل الدخول', function() {",
                  "    pm.expect(pm.response.json().success).to.be.true;",
                  "    if (pm.response.json().data.token) {",
                  "        pm.environment.set('userToken', pm.response.json().data.token);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "3. تسجيل دخول - فشل (بيانات خاطئة)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('فشل تسجيل الدخول', function() {",
                  "    pm.expect(pm.response.json().success).to.be.false;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@test.com\",\n  \"password\": \"wrongpass\"\n}"
            }
          }
        },
        {
          "name": "4. جلب معلومات المستخدم الحالي",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "5. تغيير كلمة المرور",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"password\": \"newpassword123\",\n  \"password_confirmation\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "6. تسجيل الخروج",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        }
      ]
    },
    {
