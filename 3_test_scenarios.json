{
  "info": {
    "name": "Al-Miftah API - 3 Comprehensive Test Scenarios",
    "description": "Three complete test scenarios for all user types and features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "owner_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_email",
      "value": "verified@test.com",
      "type": "string"
    },
    {
      "key": "owner_email",
      "value": "owner@test.com",
      "type": "string"
    },
    {
      "key": "admin_email",
      "value": "admin@almiftah.com",
      "type": "string"
    },
    {
      "key": "region_id",
      "value": "2",
      "type": "string"
    },
    {
      "key": "property_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "SCENARIO 1: Regular User & Owner",
      "item": [
        {
          "name": "1.1 Register - Regular User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مستخدم عادي\",\n    \"email\": \"{{user_email}}\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"966501234567\",\n    \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "1.2 Register - Property Owner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مالك عقار\",\n    \"email\": \"{{owner_email}}\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"966509999999\",\n    \"role\": \"owner\"\n}"
            }
          }
        },
        {
          "name": "1.3 Send Verification Email - User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/send-verification-email",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\"\n}"
            }
          }
        },
        {
          "name": "1.4 Verify Email - User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/verify-email",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\"\n}"
            }
          }
        },
        {
          "name": "1.5 Login - Regular User",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\",\n    \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "1.6 Login - Property Owner",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{owner_email}}\",\n    \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "1.7 Get Regions List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/regions",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "1.8 Get Properties List (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/properties",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "1.9 Get Single Property",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/properties/{{property_id}}",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "1.10 Send Contact Request",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/contact",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"property_id\": \"{{property_id}}\",\n    \"name\": \"مستخدم مهتم\",\n    \"phone\": \"966501234567\",\n    \"message\": \"أريد معرفة المزيد عن هذا العقار\"\n}"
            }
          }
        },
        {
          "name": "1.11 Get Current User Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {"key": "Authorization", "value": "Bearer {{user_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "1.12 Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/change-password",
            "header": [
              {"key": "Authorization", "value": "Bearer {{user_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"current_password\": \"password123\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "1.13 Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              {"key": "Authorization", "value": "Bearer {{user_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    },
    {
      "name": "SCENARIO 2: Admin User",
      "item": [
        {
          "name": "2.1 Login - Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{admin_email}}\",\n    \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "2.2 Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "2.3 Get All Properties (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/properties",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "2.4 Approve Property",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/properties/{{property_id}}/approve",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "2.5 Reject Property",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/properties/2/reject",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"reason\": \"العقار لا يستوفي الشروط المطلوبة\"\n}"
