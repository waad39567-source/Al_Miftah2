              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "2.7 Create New User (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/users",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"مستخدم جديد\",\n    \"email\": \"newuser@test.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"phone\": \"966508888888\",\n    \"role\": \"user\",\n    \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "2.8 Promote User to Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/promote-to-admin",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"{{user_email}}\"\n}"
            }
          }
        },
        {
          "name": "2.9 Create Region (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/regions",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"الرياض\",\n    \"type\": \"city\",\n    \"parent_id\": null\n}"
            }
          }
        },
        {
          "name": "2.10 Update Region (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/admin/regions/{{region_id}}",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Content-Type", "value": "application/json"},
