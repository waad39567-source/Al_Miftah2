            "method": "GET",
            "url": "{{base_url}}",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "3.2 Browse Regions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/regions",
            "header": [
              {"key": "Accept", "value": "application/json"}
