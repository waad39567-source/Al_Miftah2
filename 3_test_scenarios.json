            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"الرياض - تحديث\"\n}"
            }
          }
        },
        {
          "name": "2.11 Delete Region (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/regions/5",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "2.12 Get Statistics (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/statistics",
            "header": [
              {"key": "Authorization", "value": "Bearer {{admin_token}}"},
              {"key": "Accept", "value": "application/json"}
            ]
          }
        },
        {
          "name": "2.13 Logout Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
